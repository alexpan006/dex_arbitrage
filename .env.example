# ====================================
# DEX Arbitrage Bot — Environment Variables
# ====================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to version control.

# ── RPC Providers ──────────────────────────────
# Primary: Chainstack WebSocket (BSC Mainnet)
CHAINSTACK_WSS_URL=wss://bsc-mainnet.core.chainstack.com/ws/YOUR_KEY
CHAINSTACK_HTTP_URL=https://bsc-mainnet.core.chainstack.com/YOUR_KEY

# Fallback: Alchemy HTTP (BSC Mainnet)
ALCHEMY_HTTP_URL=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Private TX Submission ──────────────────────
# Multi-builder proxy for MEV protection
# Blockrazor regional endpoints: virginia / frankfurt / hongkong
BUILDER_PROXY_URL=https://hongkong.builder.blockrazor.io
# 48 Club privacy RPC (standard eth_sendRawTransaction, not broadcast to public mempool)
BUILDER_48CLUB_URL=https://rpc.48.club

# ── Wallet ─────────────────────────────────────
# Deployer & bot operator private key (no 0x prefix)
PRIVATE_KEY=your_private_key_here

# ── Contract ───────────────────────────────────
# Set after deployment (FlashSwapArbitrage address)
FLASH_SWAP_ARBITRAGE_ADDRESS=

# ── Strategy Parameters ────────────────────────
# Minimum net profit to execute (in USD)
MIN_PROFIT_THRESHOLD_USD=0.50
# Maximum flash swap borrow amount (in USD)
MAX_BORROW_AMOUNT_USD=10000
# Maximum gas price — skip opportunity if above (gwei)
MAX_GAS_PRICE_GWEI=10

# ── Monitoring ─────────────────────────────────
# Discord webhook for trade alerts & P&L reports
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_STATUS_INTERVAL_MS=300000
DISCORD_ALERT_COOLDOWN_MS=300000
DETECTOR_QUOTE_FAILURE_RATE_WARN=0.30
DETECTOR_DURATION_WARN_MS=250
DETECTOR_BUDGET_EXHAUSTED_RATE_WARN=0.20

# ── Dynamic Pool Discovery ─────────────────────
# whitelist: discover only configured token pairs/fee tiers via factory.getPool
# events: scan PoolCreated events in lookback window, then intersect between DEXs
POOL_DISCOVERY_MODE=whitelist
POOL_DISCOVERY_EVENTS_LOOKBACK_BLOCKS=100000
POOL_DISCOVERY_EVENTS_CHUNK_SIZE=5000
POOL_DISCOVERY_MAX_POOLS=200

# ── Execution Engine ───────────────────────────
# Dry-run mode: log trades without submitting (default: true)
DRY_RUN=true
# Gas limit buffer multiplier applied to estimateGas result
GAS_LIMIT_BUFFER=1.2
# Absolute gas limit cap (rejects estimates above this)
GAS_LIMIT_CAP=1000000
# How long to poll for tx receipt before timing out (ms)
TX_CONFIRMATION_TIMEOUT_MS=15000
# Interval between receipt poll attempts (ms)
RECEIPT_POLL_INTERVAL_MS=500
