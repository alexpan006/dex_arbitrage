{
  "name": "dex-arbitrage",
  "version": "0.1.0",
  "description": "Flash swap arbitrage bot for Uniswap V3 vs PancakeSwap V3 on BSC",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:fork": "hardhat test --network hardhat",
    "deploy:bsc": "hardhat run scripts/deploy.ts --network bsc",
    "start": "ts-node src/index.ts",
    "start:monitor": "ts-node scripts/monitor.ts",
    "fork:start": "bash scripts/anvil-fork.sh",
    "fork:deploy": "hardhat run scripts/deploy-fork.ts --network anvil",
    "fork:bot": "ts-node scripts/run-fork-bot.ts",
    "clean": "hardhat clean && rm -rf dist"
  },
  "dependencies": {
    "@ethersproject/abi": "^5.7.0",
    "@playwright/test": "^1.58.2",
    "@uniswap/sdk-core": "^7.12.1",
    "@uniswap/v3-sdk": "^3.29.1",
    "dotenv": "^16.4.7",
    "ethers": "^6.14.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
